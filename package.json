{
  "name": "copilot-insights",
  "version": "0.2.1",
  "description": "Copilot CLI extension that analyzes AI coding sessions for collaboration patterns, skill development, and actionable coaching.",
  "type": "module",
  "main": ".github/extensions/copilot-insights/extension.mjs",
  "bin": {
    "copilot-insights": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    ".github/extensions/",
    "src/",
    "scripts/postinstall.mjs",
    "server/index.mjs",
    "server/package.json",
    "ui/",
    "logo.svg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "npm install --legacy-peer-deps --ignore-scripts && cd server && npm install && cd ../ui && npm install && npm run build",
    "build": "cd ui && npm run build",
    "start": "cd server && node index.mjs",
    "dev": "cd server && node --watch index.mjs",
    "lint": "eslint *.mjs src/ server/ .github/extensions/",
    "test": "node --experimental-test-module-mocks --test test/*.test.mjs",
    "seed": "node scripts/seed-mock-db.mjs",
    "release": "node scripts/release.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "prepack": "cd ui && npm install && npm run build",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "ffmpeg-static": "^5.3.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "peerDependencies": {
    "@github/copilot-sdk": ">=1.0.43"
  },
  "peerDependenciesMeta": {
    "@github/copilot-sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "copilot",
    "copilot-cli",
    "extension",
    "session-analysis",
    "redirection",
    "drift-detection",
    "prompt-quality",
    "ai-prompting"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackbatzner/copilot-insights.git"
  },
  "bugs": {
    "url": "https://github.com/jackbatzner/copilot-insights/issues"
  },
  "homepage": "https://github.com/jackbatzner/copilot-insights#readme"
}
